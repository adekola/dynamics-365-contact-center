<?xml version="1.0" encoding="UTF-8"?>
<callCenter>
  <section sortOrder="0" name="reqGeneralInfo" label="General Information">
    <item sortOrder="0" name="reqInternalName" label="InternalName">D365_Contact_Center_CTI</item>
    <item sortOrder="1" name="reqDisplayName" label="Display Name">D365 Contact Center CTI</item>
    <item sortOrder="2" name="reqDescription" label="Description">Dynamics 365 Contact Center integration with Salesforce CTI featuring call time tracking</item>
    <item sortOrder="3" name="reqVersion" label="Version">1.0</item>
    <item sortOrder="4" name="reqAdapterUrl" label="CTI Adapter URL">
      <!-- Replace YOUR_DOMAIN with your actual domain -->
      https://YOUR_DOMAIN.salesforce.com/resource/CTIDriver/SFExampleCTIDriver.js
      <!-- Or use external URL: https://your-server.com/path/SFExampleCTIDriver.js -->
    </item>
    <item sortOrder="5" name="reqUseApi" label="Use CTI API">true</item>
    <item sortOrder="6" name="reqSoftphoneHeight" label="Softphone Height">300</item>
    <item sortOrder="7" name="reqSoftphoneWidth" label="Softphone Width">350</item>
    <item sortOrder="8" name="reqSalesforceCompatibilityMode" label="Salesforce Compatibility Mode">Lightning</item>
  </section>

  <section sortOrder="1" name="reqDialingOptions" label="Dialing Options">
    <item sortOrder="0" name="reqOutsidePrefix" label="Outside Prefix"></item>
    <item sortOrder="1" name="reqLongDistancePrefix" label="Long Distance Prefix"></item>
    <item sortOrder="2" name="reqInternationalPrefix" label="International Prefix"></item>
  </section>

  <section sortOrder="2" name="reqGeneralInfo" label="API Configuration">
    <item sortOrder="0" name="/reqGeneralInfo/req/enableApi" label="Enable API">true</item>
    <item sortOrder="1" name="/reqGeneralInfo/req/enableClickToDial" label="Enable Click-to-Dial">true</item>
    <item sortOrder="2" name="/reqGeneralInfo/req/enableScreenPop" label="Enable Screen Pop">true</item>
    <item sortOrder="3" name="/reqGeneralInfo/req/enableCallLogging" label="Enable Call Logging">true</item>
  </section>

  <section sortOrder="3" name="reqCallTimeTracking" label="Call Time Tracking">
    <item sortOrder="0" name="/reqCallTimeTracking/req/enableCallStartTime" label="Track Call Start Time">true</item>
    <item sortOrder="1" name="/reqCallTimeTracking/req/enableCallEndTime" label="Track Call End Time">true</item>
    <item sortOrder="2" name="/reqCallTimeTracking/req/autoCreateCase" label="Auto Create Case">true</item>
    <item sortOrder="3" name="/reqCallTimeTracking/req/linkCustomerToCase" label="Link Customer to Case">true</item>
  </section>

  <section sortOrder="4" name="reqCustomSettings" label="Custom Settings">
    <item sortOrder="0" name="/reqCustomSettings/req/caseOrigin" label="Default Case Origin">Phone</item>
    <item sortOrder="1" name="/reqCustomSettings/req/casePriority" label="Default Case Priority">Medium</item>
    <item sortOrder="2" name="/reqCustomSettings/req/caseStatus" label="Default Case Status">New</item>
    <item sortOrder="3" name="/reqCustomSettings/req/saveCallLogs" label="Save Detailed Call Logs">true</item>
  </section>

  <!-- Lightning Experience specific settings -->
  <section sortOrder="5" name="reqLightningSettings" label="Lightning Experience Settings">
    <item sortOrder="0" name="/reqLightningSettings/req/lightningMode" label="Lightning Mode">true</item>
    <item sortOrder="1" name="/reqLightningSettings/req/utilityBarIntegration" label="Utility Bar Integration">true</item>
    <item sortOrder="2" name="/reqLightningSettings/req/consoleNavigation" label="Console Navigation">true</item>
  </section>
</callCenter>
